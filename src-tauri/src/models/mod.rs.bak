//! UniRoute 核心数据模型
//!
//! 简化架构：Provider（供应商）= baseUrl + API Key + 前缀
//! 请求模型名 → Group → 模型列表 → 选择模型 → 通过前缀找 Provider → 发送请求

use chrono::{DateTime, Utc};
use serde::{Deserialize, Serialize};
use std::collections::HashMap;

// ============ 认证类型 ============

/// 认证类型
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
#[serde(rename_all = "snake_case")]
pub enum AuthType {
    ApiKey,
    OAuth,
}

impl Default for AuthType {
    fn default() -> Self {
        Self::ApiKey
    }
}

// ============ OAuth 配置 ============

/// OAuth 配置
#[derive(Debug, Clone, Serialize, Deserialize, Default)]
pub struct OAuthConfig {
    /// 客户端 ID
    pub client_id: String,
    /// 客户端密钥（可选）
    pub client_secret: Option<String>,
    /// Token URL
    pub token_url: Option<String>,
    /// 刷新 Token URL
    pub refresh_url: Option<String>,
    /// 授权 URL（设备码流程）
    pub auth_url: Option<String>,
    /// 初始化 URL（设备码流程）
    pub initiate_url: Option<String>,
    /// 轮询 URL 基础地址
    pub poll_url_base: Option<String>,
}

/// OAuth Token 信息
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct OAuthTokens {
    pub access_token: String,
    pub refresh_token: Option<String>,
    pub expires_at: Option<DateTime<Utc>>,
    pub email: Option<String>,
}

impl OAuthTokens {
    /// 检查 Token 是否过期
    pub fn is_expired(&self) -> bool {
        if let Some(expires_at) = self.expires_at {
            expires_at < Utc::now()
        } else {
            false
        }
    }

    /// 检查是否需要刷新（提前5分钟）
    pub fn needs_refresh(&self) -> bool {
        if let Some(expires_at) = self.expires_at {
            expires_at < Utc::now() + chrono::Duration::minutes(5)
        } else {
            false
        }
    }
}

// ============ 协议相关 ============

/// API 协议格式
#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq, Hash)]
#[serde(rename_all = "snake_case")]
pub enum ApiFormat {
    OpenAI,
    Claude,
    Gemini,
}

impl Default for ApiFormat {
    fn default() -> Self {
        Self::OpenAI
    }
}

impl ApiFormat {
    pub fn endpoint_path(&self) -> &'static str {
        match self {
            ApiFormat::OpenAI => "/v1/chat/completions",
            ApiFormat::Claude => "/v1/messages",
            ApiFormat::Gemini => "/v1beta/models",
        }
    }

    pub fn name(&self) -> &'static str {
        match self {
            ApiFormat::OpenAI => "OpenAI",
            ApiFormat::Claude => "Claude",
            ApiFormat::Gemini => "Gemini",
        }
    }
}

// ============ Provider（供应商） ============

/// 模型定价配置
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ModelPricing {
    /// 输入价格 ($/1M tokens)
    pub input: f64,
    /// 输出价格 ($/1M tokens)
    pub output: f64,
}

impl Default for ModelPricing {
    fn default() -> Self {
        Self {
            input: 0.0,
            output: 0.0,
        }
    }
}

/// 模型配置（包含名称和可选定价）
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ModelConfig {
    /// 模型名称
    pub name: String,
    /// 模型定价（可选）
    #[serde(default)]
    pub pricing: Option<ModelPricing>,
}

impl From<&str> for ModelConfig {
    fn from(name: &str) -> Self {
        Self {
            name: name.to_string(),
            pricing: None,
        }
    }
}

impl From<String> for ModelConfig {
    fn from(name: String) -> Self {
        Self {
            name,
            pricing: None,
        }
    }
}

// ============ 配额管理 ============

/// 配额限制配置
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct QuotaLimit {
    /// 每日限额（美元）
    #[serde(default)]
    pub daily_limit: Option<f64>,
    /// 每月限额（美元）
    #[serde(default)]
    pub monthly_limit: Option<f64>,
    /// 警告阈值（0.0-1.0，默认0.8即80%）
    #[serde(default = "default_warning_threshold")]
    pub warning_threshold: f64,
}

fn default_warning_threshold() -> f64 {
    0.8
}

impl Default for QuotaLimit {
    fn default() -> Self {
        Self {
            daily_limit: None,
            monthly_limit: None,
            warning_threshold: 0.8,
        }
    }
}

/// 配额使用状态
#[derive(Debug, Clone, Serialize, Deserialize, Default)]
pub struct QuotaStatus {
    /// 今日已使用（美元）
    pub daily_used: f64,
    /// 本月已使用（美元）
    pub monthly_used: f64,
    /// 今日剩余（美元）
    pub daily_remaining: Option<f64>,
    /// 本月剩余（美元）
    pub monthly_remaining: Option<f64>,
    /// 今日使用百分比
    pub daily_percent: Option<f64>,
    /// 本月使用百分比
    pub monthly_percent: Option<f64>,
    /// 是否超出限额
    pub is_exceeded: bool,
    /// 是否接近限额（超过警告阈值）
    pub is_warning: bool,
}

impl QuotaStatus {
    /// 计算配额状态
    pub fn compute(daily_used: f64, monthly_used: f64, limit: &QuotaLimit) -> Self {
        let daily_remaining = limit.daily_limit.map(|l| (l - daily_used).max(0.0));
        let monthly_remaining = limit.monthly_limit.map(|l| (l - monthly_used).max(0.0));

        let daily_percent = limit
            .daily_limit
            .map(|l| (daily_used / l * 100.0).min(100.0));
        let monthly_percent = limit
            .monthly_limit
            .map(|l| (monthly_used / l * 100.0).min(100.0));

        let daily_exceeded = limit.daily_limit.map(|l| daily_used >= l).unwrap_or(false);
        let monthly_exceeded = limit
            .monthly_limit
            .map(|l| monthly_used >= l)
            .unwrap_or(false);
        let is_exceeded = daily_exceeded || monthly_exceeded;

        let daily_warning = limit
            .daily_limit
            .map(|l| daily_used / l >= limit.warning_threshold)
            .unwrap_or(false);
        let monthly_warning = limit
            .monthly_limit
            .map(|l| monthly_used / l >= limit.warning_threshold)
            .unwrap_or(false);
        let is_warning = !is_exceeded && (daily_warning || monthly_warning);

        Self {
            daily_used,
            monthly_used,
            daily_remaining,
            monthly_remaining,
            daily_percent,
            monthly_percent,
            is_exceeded,
            is_warning,
        }
    }

    /// 检查是否允许请求
    pub fn allow_request(&self) -> Result<(), String> {
        if self.is_exceeded {
            let msg = if self.daily_remaining.is_some() {
                format!("每日配额已用完（已使用 ${:.4}）", self.daily_used)
            } else {
                format!("每月配额已用完（已使用 ${:.4}）", self.monthly_used)
            };
            Err(msg)
        } else {
            Ok(())
        }
    }
}

/// Provider（供应商）
///
/// 一个供应商 = 一个 API 服务
/// 包含：名称、前缀、baseUrl、API Key
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Provider {
    pub id: String,               // UUID
    pub name: String,             // 显示名称，如 "DeepSeek"、"我的 Ollama"
    pub prefix: String,           // 路由前缀，如 "ds"、"ollama"
    pub base_url: String,         // API 基础地址
    pub api_key: Option<String>,  // API 密钥
    pub api_format: ApiFormat,    // 协议格式
    pub models: Vec<ModelConfig>, // 支持的模型列表（含定价）
    /// 是否启用成本统计
    #[serde(default)]
    pub enable_cost: bool,
    /// 认证类型
    #[serde(default)]
    pub auth_type: AuthType,
    /// OAuth 配置
    #[serde(default)]
    pub oauth: Option<OAuthConfig>,
    /// OAuth Token（运行时）
    #[serde(default, skip_serializing_if = "Option::is_none")]
    pub oauth_tokens: Option<OAuthTokens>,
    /// 额外请求头
    #[serde(default)]
    pub headers: HashMap<String, String>,
    /// 认证头名称
    #[serde(default = "default_auth_header")]
    pub auth_header: String,
    /// 认证前缀
    #[serde(default)]
    pub auth_prefix: Option<String>,
    pub is_active: bool,  // 是否启用
    pub is_builtin: bool, // 是否内置模板
    pub created_at: DateTime<Utc>,
    pub updated_at: DateTime<Utc>,
}

fn default_auth_header() -> String {
    "Authorization".to_string()
}

impl Provider {
    /// 创建新的自定义 Provider
    pub fn new(name: String, prefix: String, base_url: String) -> Self {
        let now = Utc::now();
        Self {
            id: uuid::Uuid::new_v4().to_string(),
            name,
            prefix,
            base_url,
            api_key: None,
            api_format: ApiFormat::OpenAI,
            models: vec![ModelConfig::from("*")],
            enable_cost: false, // 默认不计费
            auth_type: AuthType::ApiKey,
            oauth: None,
            oauth_tokens: None,
            headers: HashMap::new(),
            auth_header: "Authorization".to_string(),
            auth_prefix: None,
            is_active: true,
            is_builtin: false,
            created_at: now,
            updated_at: now,
        }
    }

    /// 检查是否需要 OAuth 认证
    pub fn needs_oauth(&self) -> bool {
        self.auth_type == AuthType::OAuth && self.oauth_tokens.is_none()
    }

    /// 检查 OAuth Token 是否需要刷新
    pub fn needs_token_refresh(&self) -> bool {
        if self.auth_type != AuthType::OAuth {
            return false;
        }
        if let Some(tokens) = &self.oauth_tokens {
            tokens.needs_refresh()
        } else {
            true
        }
    }

    /// 获取认证头值
    pub fn get_auth_value(&self) -> Option<String> {
        match self.auth_type {
            AuthType::ApiKey => {
                self.api_key.as_ref().map(|key| {
                    if let Some(prefix) = &self.auth_prefix {
                        // 如果有明确的前缀配置，使用配置的前缀
                        if prefix.is_empty() {
                            key.clone()
                        } else {
                            format!("{} {}", prefix, key)
                        }
                    } else {
                        // 根据认证头名称推断默认行为
                        // Authorization 头通常需要 Bearer 前缀
                        // x-api-key 等其他头通常不需要前缀
                        let header_lower = self.auth_header.to_lowercase();
                        if header_lower == "authorization" {
                            format!("Bearer {}", key)
                        } else {
                            key.clone()
                        }
                    }
                })
            }
            AuthType::OAuth => self
                .oauth_tokens
                .as_ref()
                .map(|t| format!("Bearer {}", t.access_token)),
        }
    }

    /// 获取模型列表（只返回名称）
    pub fn model_names(&self) -> Vec<String> {
        self.models.iter().map(|m| m.name.clone()).collect()
    }

    /// 获取模型定价
    pub fn get_model_pricing(&self, model_name: &str) -> Option<&ModelPricing> {
        self.models
            .iter()
            .find(|m| m.name == model_name || m.name == "*")
            .and_then(|m| m.pricing.as_ref())
    }

