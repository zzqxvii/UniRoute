// ============ 请求日志 ============

/// 请求日志
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct RequestLog {
    pub id: i64,
    pub timestamp: DateTime<Utc>,
    pub method: String,
    pub path: String,
    /// 用户请求的模型名（可能是 Group 名称）
    pub requested_model: Option<String>,
    /// 实际使用的模型名
    pub model: Option<String>,
    /// Provider 名称
    pub provider: Option<String>,
    /// Provider 前缀
    pub provider_prefix: Option<String>,
    /// 实际请求的 URL
    pub url: Option<String>,
    /// 协议转换类型: "direct" 直发, "OpenAI->Claude" 等
    pub protocol_transform: Option<String>,
    pub status_code: i32,
    pub latency_ms: i64,
    /// 首 token 延迟（流式请求）
    pub first_token_ms: Option<i64>,
    pub prompt_tokens: Option<i32>,
    pub completion_tokens: Option<i32>,
    /// 请求成本（美元）
    pub cost: Option<f64>,
    pub error: Option<String>,
    pub request_body: Option<String>,
    pub response_body: Option<String>,
}

impl RequestLog {
    pub fn new(method: String, path: String) -> Self {
        Self {
            id: 0,
            timestamp: Utc::now(),
            method,
            path,
            requested_model: None,
            model: None,
            provider: None,
            provider_prefix: None,
            url: None,
            protocol_transform: None,
            status_code: 0,
            latency_ms: 0,
            first_token_ms: None,
            prompt_tokens: None,
            completion_tokens: None,
            cost: None,
            error: None,
            request_body: None,
            response_body: None,
        }
    }

    pub fn with_requested_model(mut self, model: String) -> Self {
        self.requested_model = Some(model);
        self
    }

    pub fn with_model(mut self, model: String) -> Self {
        self.model = Some(model);
        self
    }

    pub fn with_provider(mut self, name: String, prefix: String) -> Self {
        self.provider = Some(name);
        self.provider_prefix = Some(prefix);
        self
    }

    pub fn with_url(mut self, url: String) -> Self {
        self.url = Some(url);
        self
    }

    pub fn with_protocol_transform(mut self, transform: String) -> Self {
        self.protocol_transform = Some(transform);
        self
    }

    pub fn with_status(mut self, status: i32) -> Self {
        self.status_code = status;
        self
    }

    pub fn with_latency(mut self, ms: i64) -> Self {
        self.latency_ms = ms;
        self
    }

    pub fn with_first_token(mut self, ms: i64) -> Self {
        self.first_token_ms = Some(ms);
        self
    }

    pub fn with_tokens(mut self, prompt: i32, completion: i32) -> Self {
        self.prompt_tokens = Some(prompt);
        self.completion_tokens = Some(completion);
        self
    }

    pub fn with_cost(mut self, cost: f64) -> Self {
        self.cost = Some(cost);
        self
    }

    pub fn with_error(mut self, error: String) -> Self {
        self.error = Some(error);
        self
    }

    pub fn with_request(mut self, body: String) -> Self {
        self.request_body = Some(body);
        self
    }

    pub fn with_response(mut self, body: String) -> Self {
        self.response_body = Some(body);
        self
    }
}
