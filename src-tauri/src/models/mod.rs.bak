// ============ Group（路由组） ============

/// Group 策略
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
#[serde(rename_all = "snake_case")]
pub enum GroupStrategy {
    Priority,      // 按优先级顺序
    Weighted,      // 按权重随机
    RoundRobin,    // 轮询
    Random,        // 随机打乱
    LeastUsed,     // 最少使用优先
    CostOptimized, // 成本优化
}

impl Default for GroupStrategy {
    fn default() -> Self {
        Self::Priority
    }
}

/// Group 中的模型项
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct GroupModel {
    pub model: String, // 格式: "provider/model" 或 "model"
    pub weight: u32,   // 权重（用于 weighted 策略）
    pub priority: u32, // 优先级（数字越小越优先）
}

impl GroupModel {
    pub fn new(model: String) -> Self {
        Self {
            model,
            weight: 1,
            priority: 0,
        }
    }

    pub fn with_priority(mut self, priority: u32) -> Self {
        self.priority = priority;
        self
    }

    pub fn with_weight(mut self, weight: u32) -> Self {
        self.weight = weight;
        self
    }
}

/// Group 配置
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct GroupConfig {
    #[serde(default = "default_max_retries")]
    pub max_retries: u32,
    #[serde(default = "default_retry_delay")]
    pub retry_delay_ms: u32,
    #[serde(default)]
    pub timeout_ms: Option<u32>,
}

fn default_max_retries() -> u32 {
    3
}
fn default_retry_delay() -> u32 {
    1000
}

impl Default for GroupConfig {
    fn default() -> Self {
        Self {
            max_retries: 3,
            retry_delay_ms: 1000,
            timeout_ms: None,
        }
    }
}

/// Group（路由组）
///
/// 示例：
/// ```text
/// Group {
///     name: "gpt-4",
///     models: [
///         GroupModel { model: "openai/gpt-4", priority: 0 },
///         GroupModel { model: "azure/gpt-4", priority: 1 },
///         GroupModel { model: "api2d/gpt-4", priority: 2 },
///     ],
///     strategy: Priority,
/// }
/// ```
///
/// 请求 model="gpt-4" 时，按优先级依次尝试 openai、azure、api2d
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Group {
    pub id: String,
    pub name: String, // Group 名称，请求时使用
    pub description: Option<String>,
    pub models: Vec<GroupModel>, // 模型列表
    pub strategy: GroupStrategy,
    pub config: GroupConfig,
    pub is_active: bool,
    pub created_at: DateTime<Utc>,
    pub updated_at: DateTime<Utc>,
}

impl Group {
    pub fn new(name: String) -> Self {
        let now = Utc::now();
        Self {
            id: uuid::Uuid::new_v4().to_string(),
            name,
            description: None,
            models: Vec::new(),
            strategy: GroupStrategy::default(),
            config: GroupConfig::default(),
            is_active: true,
            created_at: now,
            updated_at: now,
        }
    }

    pub fn add_model(&mut self, model: GroupModel) {
        self.models.push(model);
        self.updated_at = Utc::now();
    }

    /// 获取排序后的模型列表（按策略）
    pub fn get_ordered_models(&self) -> Vec<&GroupModel> {
        let mut models: Vec<_> = self.models.iter().collect();
        match self.strategy {
            GroupStrategy::Priority => {
                models.sort_by_key(|m| m.priority);
            }
            GroupStrategy::Weighted | GroupStrategy::Random => {
                // 保持原顺序或随机
            }
            GroupStrategy::RoundRobin => {
                // TODO: 需要维护状态
                models.sort_by_key(|m| m.priority);
            }
            GroupStrategy::LeastUsed | GroupStrategy::CostOptimized => {
                // TODO: 需要实际数据
                models.sort_by_key(|m| m.priority);
            }
        }
        models
    }
}

// ============ 模型映射（可选） ============

/// 模型名模式 → Group 映射
///
/// 支持通配符：
/// - "claude-*" → 匹配所有 claude 开头的模型
/// - "gpt-4*" → 匹配 gpt-4, gpt-4-turbo, gpt-4o 等
/// - "*" → 默认兜底
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ModelMapping {
    pub id: String,
    pub pattern: String,  // glob 模式
    pub group_id: String, // 指向的 Group
    pub priority: u32,    // 匹配优先级（数字越小越优先）
}

impl ModelMapping {
    pub fn new(pattern: String, group_id: String) -> Self {
        Self {
            id: uuid::Uuid::new_v4().to_string(),
            pattern,
            group_id,
            priority: 0,
        }
    }

    /// 检查模型名是否匹配此模式
    pub fn matches(&self, model: &str) -> bool {
        if self.pattern == "*" {
            return true;
        }
        if self.pattern.ends_with('*') {
            let prefix = &self.pattern[..self.pattern.len() - 1];
            return model.starts_with(prefix);
        }
        if self.pattern.starts_with('*') {
            let suffix = &self.pattern[1..];
            return model.ends_with(suffix);
        }
        self.pattern == model
    }
}

